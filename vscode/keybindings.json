// Place your key bindings in this file to override the defaultsauto[]
[
    {
        "key": "ctrl+f10",
        "command": "python.execInTerminal"
    },
    {
        "key": "ctrl+. ctrl+.",
        "command": "editor.debug.action.selectionToRepl"
    },
    {
        "key": "ctrl+. ctrl+,",
        "command": "editor.action.quickFix",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+. ctrl+,",
        "command": "problems.action.showQuickFixes",
        "when": "problemFocus"
    },
    // {
    //     "key": "ctrl+x k",
    //     "command": "workbench.action.navigateUp"
    // },
    // {
    //     "key": "ctrl+x j",
    //     "command": "workbench.action.navigateDown"
    // },
    // {
    //     "key": "ctrl+x h",
    //     "command": "workbench.action.navigateLeft"
    // },
    // {
    //     "key": "ctrl+x l",
    //     "command": "workbench.action.navigateRight"
    // },
    {
        "key": "ctrl+k",
        "command": "workbench.action.navigateUp"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.navigateDown"
    },
    {
        "key": "ctrl+h",
        "command": "workbench.action.navigateLeft"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.navigateRight"
    },
    //Move lines
    {
        "key": "alt+j",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+down",
        "command": "-editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+k",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+up",
        "command": "-editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    // Vim keybindings for IntelliSense popup window
    // For quick menu navigation 
    // https://stackoverflow.com/questions/74732424/visual-studio-code-keybinding-for-navigation-in-quick-fix-contextual-menu
    {
        "key": "alt+k",
        "when": "codeActionMenuVisible",
        "command": "selectPrevCodeAction"
    },
    {
        "key": "alt+j",
        "when": "codeActionMenuVisible",
        "command": "selectNextCodeAction"
    },
    //Intellisense suggestions
    // https://airyboy.medium.com/using-vim-like-navigation-for-intellisense-suggestions-in-vscode-3c310ac73844
    {
        "key": "alt+j",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "alt+k",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "ctrl+.",
        "command": "-workbench.action.chat.toggleAgentMode",
        "when": "chatHasToolsAgent && inChatInput && !chatSessionRequestInProgress && chatLocation == 'editing-session'"
    }
]
